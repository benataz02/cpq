{
  "name": "cpq",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": { "node": ">=24" },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check": "turbo run typecheck lint test build",
    "dev": "turbo run dev --filter=@cpq/api --filter=@cpq/web",
    "dev:api": "turbo run dev --filter=@cpq/api",
    "dev:web": "turbo run dev --filter=@cpq/web"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.9",
    "eslint": "^10.4",
    "eslint-plugin-boundaries": "^6",
    "typescript-eslint": "^8",
    "vitest": "^3",
    "jsdom": "^25",
    "fast-check": "^4",
    "tsx": "^4"
  }
}
