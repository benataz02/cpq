# Local dev environment — copy to `.env` (gitignored) and fill in real values.
#
#   cp .env.example .env
#
# Loaded automatically by `pnpm dev` (apps/api uses Node's --env-file-if-exists, so a
# missing .env is a no-op — production/Docker injects env directly and ships no .env file).
#
# NOTE: vitest does NOT auto-load this file. To run the LIVE SAP acceptance test with these
# values:  `node --env-file=.env --import tsx node_modules/vitest/vitest.mjs run`  — or just
# export the SAP_* vars in your shell.  (`pnpm -F @cpq/sap-b1 test` alone won't read .env.)

# --- API server ---
PORT=3000
LOG_LEVEL=info

# --- Postgres (apps/api + @cpq/db) ---
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/postgres

# --- SAP Business One Service Layer (@cpq/sap-b1) ---
# SAP_BASE_URL is the one required field (resolveSapConfig throws without it).
SAP_BASE_URL=https://your-b1-host:50000/b1s/v2
SAP_COMPANY_DB=SBODEMO
SAP_USERNAME=manager
SAP_PASSWORD=
# Set 'false' for the sandbox's self-signed TLS cert; omit/true in production.
SAP_REJECT_UNAUTHORIZED=false

# --- Anthropic (P4 — optional; manual mode degrades gracefully without a key) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
